<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Account Contact Manager PS</label>
    <description>Grants access to the Account Contact Manager app, tab, and Apex controller.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- Custom App visibility -->
    <applicationVisibilities>
        <application>AccountContactApp</application>
        <visible>true</visible>
    </applicationVisibilities>

    <!-- Custom Tab visibility -->
    <tabSettings>
        <tab>AccountContactManager</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <!-- Apex class access -->
    <classAccesses>
        <apexClass>AccountContactController</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- Object permissions: read/edit on Account -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Account</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Object permissions: read/edit on Contact -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Contact</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Account field-level access -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Phone</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Industry</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.AnnualRevenue</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Contact field-level access -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Contact.Email</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Contact.Phone</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Contact.Title</field>
        <readable>true</readable>
    </fieldPermissions>
</PermissionSet>
